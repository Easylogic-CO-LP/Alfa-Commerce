<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">

        <!-- ── Text search ──────────────────────────────────────────────── -->
        <field
                name="search"
                type="text"
                hint="COM_ALFA_SEARCH_FILTER_SUBMIT"
                label="COM_USERS_FILTER_SEARCH_DESC"
                class="js-stools-search-string"
        />

        <!-- ── Category filter ──────────────────────────────────────────── -->
        <!--
            IMPORTANT: type="sql" against #__alfa_categories, NOT type="categories"
            which would query #__categories (Joomla content categories).

            NO <option> children on multi-select filter fields.
            The fancy-select widget renders any child <option> as a pre-selected
            chip on page load, even when the filter value is empty.
            Empty selection already means "all" — the placeholder handles the UX.
        -->
        <field
                name="category"
                type="sql"
                multiple="true"
                label="COM_ALFA_FILTER_CATEGORY_LBL"
                layout="joomla.form.field.list-fancy-select"
                query="SELECT `id`, `name` AS val FROM `#__alfa_categories` WHERE `state` = 1 ORDER BY `name` ASC"
                key_field="id"
                value_field="val"
                onchange="this.form.submit();"
                hint="COM_ALFA_FILTER_ALL_CATEGORIES"
        />

        <!-- ── Manufacturer filter ──────────────────────────────────────── -->
        <!--
            NO <option> children — same reason as categories above.
            hint= provides the "all manufacturers" placeholder text.
        -->
        <field
                name="manufacturer"
                type="sql"
                multiple="true"
                label="COM_ALFA_FILTER_MANUFACTURER_LBL"
                layout="joomla.form.field.list-fancy-select"
                query="SELECT `id`, `name` AS val FROM `#__alfa_manufacturers` ORDER BY `name` ASC"
                key_field="id"
                value_field="val"
                onchange="this.form.submit();"
                hint="COM_ALFA_FILTER_ALL_MANUFACTURERS"
        />

        <!-- ── Price range ───────────────────────────────────────────────── -->
        <!--
            price_min and price_max feed the range slider on the front end.
            Both map to pf.final_price in the index subquery — the price the
            visitor actually pays (after discounts and tax).
            The slider JS populates these fields and submits the form.
        -->
        <field
                name="price_min"
                type="number"
                step="0.01"
                min="0"
                label="COM_ALFA_FILTER_PRICE_MIN_LBL"
                hint="COM_ALFA_FILTER_PRICE_MIN_HINT"
        />

        <field
                name="price_max"
                type="number"
                step="0.01"
                min="0"
                label="COM_ALFA_FILTER_PRICE_MAX_LBL"
                hint="COM_ALFA_FILTER_PRICE_MAX_HINT"
        />

        <!-- ── On sale ───────────────────────────────────────────────────── -->
        <!--
            When set to 1: WHERE pf.discount_amount > 0
            Shows only items that have an active discount for this visitor.
            Empty value = show all items.
        -->
        <field
                name="on_sale"
                type="radio"
                label="COM_ALFA_FILTER_ON_SALE_LBL"
                class="btn-group"
                onchange="this.form.submit();"
        >
            <option value="">COM_ALFA_FILTER_ON_SALE_ALL</option>
            <option value="1">COM_ALFA_FILTER_ON_SALE_YES</option>
        </field>

        <!-- ── Minimum discount amount ──────────────────────────────────── -->
        <!--
            Maps to: WHERE pf.discount_amount >= X
            "Show me items where I save at least €10."
        -->
        <field
                name="discount_amount_min"
                type="number"
                step="0.01"
                min="0"
                label="COM_ALFA_FILTER_DISCOUNT_AMOUNT_MIN_LBL"
                hint="COM_ALFA_FILTER_DISCOUNT_AMOUNT_MIN_HINT"
        />

        <!-- ── Minimum discount percentage ──────────────────────────────── -->
        <!--
            Maps to: WHERE pf.discount_percent >= X
            "Show me items discounted by at least 20%."
        -->
        <field
                name="discount_percent_min"
                type="number"
                step="1"
                min="0"
                max="100"
                label="COM_ALFA_FILTER_DISCOUNT_PERCENT_MIN_LBL"
                hint="COM_ALFA_FILTER_DISCOUNT_PERCENT_MIN_HINT"
        />

    </fields>

    <fields name="list">

        <!-- ── Sort order ────────────────────────────────────────────────── -->
        <!--
            pf.final_price / pf.discount_amount / pf.discount_percent all
            require that these column names are present in ItemsModel::$filter_fields
            (see constructor). parseFullordering() in UrlListModel does:
              in_array($orderCol, $this->filter_fields)
            and silently falls back to default if the column is missing.
        -->
        <field
                name="fullordering"
                type="list"
                label="COM_ALFA_LIST_FULL_ORDERING"
                description="COM_ALFA_LIST_FULL_ORDERING_DESC"
                onchange="this.form.submit();"
                default="a.id DESC"
        >
            <option value="a.ordering ASC">COM_ALFA_ORDERING_ASC</option>
            <option value="a.ordering DESC">COM_ALFA_ORDERING_DESC</option>
            <option value="a.name ASC">COM_ALFA_NAME_ASC</option>
            <option value="a.name DESC">COM_ALFA_NAME_DESC</option>
            <option value="a.id ASC">COM_ALFA_ID_ASC</option>
            <option value="a.id DESC">COM_ALFA_ID_DESC</option>
            <option value="a.sku ASC">COM_ALFA_SKU_ASC</option>
            <option value="a.sku DESC">COM_ALFA_SKU_DESC</option>
            <option value="a.stock ASC">COM_ALFA_STOCK_ASC</option>
            <option value="a.stock DESC">COM_ALFA_STOCK_DESC</option>
            <!-- Requires 'pf.final_price' in ItemsModel::$filter_fields -->
            <option value="pf.final_price ASC">COM_ALFA_PRICE_ASC</option>
            <option value="pf.final_price DESC">COM_ALFA_PRICE_DESC</option>
            <!-- Requires 'pf.discount_amount' in ItemsModel::$filter_fields -->
            <option value="pf.discount_amount DESC">COM_ALFA_DISCOUNT_AMOUNT_DESC</option>
            <!-- Requires 'pf.discount_percent' in ItemsModel::$filter_fields -->
            <option value="pf.discount_percent DESC">COM_ALFA_DISCOUNT_PERCENT_DESC</option>
        </field>

        <field
                name="limit"
                type="limitbox"
                label="COM_ALFA_LIST_LIMIT"
                description="COM_ALFA_LIST_LIMIT_DESC"
                class="input-mini"
                default="25"
                onchange="this.form.submit();"
        />

    </fields>
</form>