<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_ALFA_CART_NAME</name>
    <author>Dimitris Papanotas</author>
    <creationDate>2024-11-7</creationDate>
    <copyright>(C) 2024 Open Source Matters, Inc.</copyright>
    <license>GNU General Public License version 3 or later; see LICENSE</license>
    <authorEmail>dimitris.papanotas@gmail.com</authorEmail>
    <version>1.0.0</version>
    <description>MOD_ALFA_CART_DESC</description>
    <namespace path="src">Alfa\Module\AlfaCart</namespace>
    <files>
        <folder module="mod_alfa_cart">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>
    <media destination="mod_alfa_cart" folder="media">
        <filename>joomla.asset.json</filename>
        <folder>js</folder>
        <folder>css</folder>
    </media>
    <languages folder="language">
        <language tag="en-GB">en-GB/mod_alfa_cart.ini</language>
        <language tag="en-GB">en-GB/mod_alfa_cart.sys.ini</language>
        <language tag="el-GR">el-GR/mod_alfa_cart.ini</language>
        <language tag="el-GR">el-GR/mod_alfa_cart.sys.ini</language>
    </languages>


    <config>
        <fields name="params">
            <fieldset name="basic">

                 <field name="animation" type="radio" class="btn-group" default="zoomIn"
                       label="MOD_ALFA_CART_OPEN_ANIMATION"
                       description="MOD_ALFA_CART_OPEN_ANIMATION_DESC">
                    <option value="zoomIn">MOD_ALFA_CART_OPTION_ZOOM_IN</option>
                    <option value="fromTop">MOD_ALFA_CART_OPTION_FROM_TOP</option>
                    <option value="fromLeft">MOD_ALFA_CART_OPTION_FROM_LEFT</option>
                    <option value="fromRight">MOD_ALFA_CART_OPTION_FROM_RIGHT</option>
                </field>

                <field
                        type="spacer"
                        label="MOD_ALFA_CART_IMAGE_SPACER"
                />

                <field name="imageType" type="radio" class="btn-group" default="3"
                       label="MOD_ALFA_CART_IMAGE_TYPE_LBL"
                       description="MOD_ALFA_CART_IMAGE_TYPE_DESC">
                    <option value="0">MOD_ALFA_CART_OPTION_IMAGE</option>
                    <option value="1">MOD_ALFA_CART_OPTION_INLINE_SVG</option>
                    <option value="3">MOD_ALFA_CART_OPTION_DEFAULT</option>
                </field>

                <field
                        name="imageFile"
                        type="media"
                        label="MOD_ALFA_CART_IMAGE_FILE_LBL"
                        description="MOD_ALFA_CART_IMAGE_FILE_DESC"
                        default=""
                        required="false"
                        showon="imageType:0"
                />

                <field
                        name="imageInline"
                        type="textarea"
                        label="MOD_ALFA_CART_IMAGE_INLINE_LBL"
                        description="MOD_ALFA_CART_IMAGE_INLINE_DESC"
                        filter="raw"
                        showon="imageType:1"
                        rows="5"
                        cols="30"
                />

                <field name="togglerCounterValue" type="radio" class="btn-group" default="0"
                       label="MOD_ALFA_CART_TOGGLER_VALUE_LBL"
                       description="MOD_ALFA_CART_TOGGLER_VALUE_DESC">
                    <option value="0">MOD_ALFA_CART_OPTION_TOTAL_QUANTITY</option>
                    <option value="1">MOD_ALFA_CART_OPTION_TOTAL_ITEMS</option>
                </field>

                <field name="togglerColor"
                       type="color"
                       default="#FFFFFF"
                       format="rgba"
                       label="MOD_ALFA_CART_TOGGLER_COLOR_LBL"
                       description="MOD_ALFA_CART_TOGGLER_COLOR_DESC"
                />

                <field name="togglerCounterColor"
                       type="color"
                       default="#FF0000"
                       format="rgba"
                       label="MOD_ALFA_CART_TOGGLER_BACKGROUND_COLOR_LBL"
                       description="MOD_ALFA_CART_TOGGLER_BACKGROUND_COLOR_DESC"
                />
            </fieldset>

            <!-- Price Display Settings -->
            <fieldset name="price_display" label="MOD_ALFA_CART_PRICE_DISPLAY_SETTINGS">

                <field
                        type="note"
                        label="MOD_ALFA_CART_PRICE_NOTE"
                        description="MOD_ALFA_CART_PRICE_NOTE_DESC"
                        class="alert alert-info"
                />

                <!-- Base Price -->
                <fieldset name="base_price" label="MOD_ALFA_CART_BASE_PRICE_LABEL">
                    <field
                            name="base_price_show"
                            type="radio"
                            default="0"
                            label="MOD_ALFA_CART_BASE_PRICE_SHOW_LABEL"
                            description="MOD_ALFA_CART_BASE_PRICE_SHOW_DESC"
                            class="btn-group"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                    <field
                            name="base_price_show_label"
                            type="radio"
                            default="1"
                            label="MOD_ALFA_CART_SHOW_LABEL"
                            description="MOD_ALFA_CART_BASE_PRICE_LABEL_DESC"
                            class="btn-group"
                            showon="base_price_show:1"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                </fieldset>

                <!-- Discount Amount -->
                <fieldset name="discount_amount" label="MOD_ALFA_CART_DISCOUNT_LABEL">
                    <field
                            name="discount_amount_show"
                            type="radio"
                            default="0"
                            label="MOD_ALFA_CART_DISCOUNT_SHOW_LABEL"
                            description="MOD_ALFA_CART_DISCOUNT_SHOW_DESC"
                            class="btn-group"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                    <field
                            name="discount_amount_show_label"
                            type="radio"
                            default="1"
                            label="MOD_ALFA_CART_SHOW_LABEL"
                            description="MOD_ALFA_CART_DISCOUNT_LABEL_DESC"
                            class="btn-group"
                            showon="discount_amount_show:1"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                </fieldset>

                <!-- Subtotal (After Discounts) -->
                <fieldset name="base_price_with_discounts" label="MOD_ALFA_CART_SUBTOTAL_LABEL">
                    <field
                            name="base_price_with_discounts_show"
                            type="radio"
                            default="0"
                            label="MOD_ALFA_CART_SUBTOTAL_SHOW_LABEL"
                            description="MOD_ALFA_CART_SUBTOTAL_SHOW_DESC"
                            class="btn-group"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                    <field
                            name="base_price_with_discounts_show_label"
                            type="radio"
                            default="1"
                            label="MOD_ALFA_CART_SHOW_LABEL"
                            description="MOD_ALFA_CART_SUBTOTAL_LABEL_DESC"
                            class="btn-group"
                            showon="base_price_with_discounts_show:1"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                </fieldset>

                <!-- Tax Amount -->
                <fieldset name="tax_amount" label="MOD_ALFA_CART_TAX_LABEL">
                    <field
                            name="tax_amount_show"
                            type="radio"
                            default="0"
                            label="MOD_ALFA_CART_TAX_SHOW_LABEL"
                            description="MOD_ALFA_CART_TAX_SHOW_DESC"
                            class="btn-group"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                    <field
                            name="tax_amount_show_label"
                            type="radio"
                            default="1"
                            label="MOD_ALFA_CART_SHOW_LABEL"
                            description="MOD_ALFA_CART_TAX_LABEL_DESC"
                            class="btn-group"
                            showon="tax_amount_show:1"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                </fieldset>

                <!-- Base Price with Tax -->
                <fieldset name="base_price_with_tax" label="MOD_ALFA_CART_BASE_WITH_TAX_LABEL">
                    <field
                            name="base_price_with_tax_show"
                            type="radio"
                            default="0"
                            label="MOD_ALFA_CART_BASE_WITH_TAX_SHOW_LABEL"
                            description="MOD_ALFA_CART_BASE_WITH_TAX_SHOW_DESC"
                            class="btn-group"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                    <field
                            name="base_price_with_tax_show_label"
                            type="radio"
                            default="1"
                            label="MOD_ALFA_CART_SHOW_LABEL"
                            description="MOD_ALFA_CART_BASE_WITH_TAX_LABEL_DESC"
                            class="btn-group"
                            showon="base_price_with_tax_show:1"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                </fieldset>

                <!-- Final Price -->
                <fieldset name="final_price" label="MOD_ALFA_CART_FINAL_PRICE_LABEL">
                    <field
                            name="final_price_show"
                            type="radio"
                            default="1"
                            label="MOD_ALFA_CART_FINAL_PRICE_SHOW_LABEL"
                            description="MOD_ALFA_CART_FINAL_PRICE_SHOW_DESC"
                            class="btn-group"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                    <field
                            name="final_price_show_label"
                            type="radio"
                            default="0"
                            label="MOD_ALFA_CART_SHOW_LABEL"
                            description="MOD_ALFA_CART_FINAL_PRICE_LABEL_DESC"
                            class="btn-group"
                            showon="final_price_show:1"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                </fieldset>

                <!-- Price Breakdown -->
                <fieldset name="price_breakdown" label="MOD_ALFA_CART_BREAKDOWN_LABEL">
                    <field
                            name="price_breakdown_show"
                            type="radio"
                            default="0"
                            label="MOD_ALFA_CART_BREAKDOWN_SHOW_LABEL"
                            description="MOD_ALFA_CART_BREAKDOWN_SHOW_DESC"
                            class="btn-group"
                    >
                        <option value="1">JSHOW</option>
                        <option value="0">JHIDE</option>
                    </field>
                </fieldset>

            </fieldset>
        </fields>
    </config>

</extension>