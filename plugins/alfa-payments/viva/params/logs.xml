<?xml version="1.0" encoding="UTF-8"?>
<form>
	<fields name="paymentslogs">
		<fieldset name="paymentslogs">
			<field name="action"              mysql_type="varchar(60)"   default="NULL"                label="PLG_ALFA_PAYMENTS_VIVA_LOG_ACTION"/>
			<field name="transaction_status"  mysql_type="varchar(20)"   default="NULL"                label="PLG_ALFA_PAYMENTS_VIVA_LOG_STATUS"/>
			<field name="viva_order_code"     mysql_type="varchar(40)"   default="NULL"                label="PLG_ALFA_PAYMENTS_VIVA_LOG_ORDER_CODE"/>
			<field name="viva_transaction_id" mysql_type="varchar(254)"  default="NULL"                label="PLG_ALFA_PAYMENTS_VIVA_LOG_TRANSACTION_ID"/>
			<field name="intent"              mysql_type="varchar(20)"   default="NULL"                label="PLG_ALFA_PAYMENTS_VIVA_LOG_INTENT"/>
			<field name="amount"              mysql_type="decimal(20,6)" default="0.000000"            label="PLG_ALFA_PAYMENTS_VIVA_LOG_AMOUNT"/>
			<field name="currency"            mysql_type="char(3)"       default="NULL"                label="PLG_ALFA_PAYMENTS_VIVA_LOG_CURRENCY"/>
			<field name="note"                mysql_type="varchar(500)"  default="NULL"                label="PLG_ALFA_PAYMENTS_VIVA_LOG_NOTE"/>
			<field name="created_on"          mysql_type="datetime"      default="0000-00-00 00:00:00" label="PLG_ALFA_PAYMENTS_VIVA_LOG_CREATED_ON"/>
			<field name="created_by"          mysql_type="int(11)"       default="0"                   label="PLG_ALFA_PAYMENTS_VIVA_LOG_CREATED_BY"/>
		</fieldset>
	</fields>
</form>
