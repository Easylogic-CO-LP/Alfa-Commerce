<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="alfa-payments" method="upgrade">
	<name>PLG_ALFA_PAYMENTS_REVOLUT</name>
	<copyright>(C) 2024-2026 Alfa. All rights reserved.</copyright>
	<license>GNU General Public License version 3 or later; see LICENSE</license>
	<author>Alfa</author>
	<creationDate>2025-04-16</creationDate>
	<authorUrl>https://alfa.gr</authorUrl>
	<version>1.0.0</version>
	<description>PLG_ALFA_PAYMENTS_REVOLUT_XML_DESCRIPTION</description>
	<namespace path="src">Alfa\Plugin\AlfaPayments\Revolut</namespace>
	<files>
		<folder plugin="revolut">services</folder>
		<folder>src</folder>
		<folder>tmpl</folder>
		<folder>params</folder>
		<folder>libraries</folder>
	</files>
	<languages folder="language">
		<language tag="en-GB">en-GB/plg_alfa-payments_revolut.ini</language>
		<language tag="en-GB">en-GB/plg_alfa-payments_revolut.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="basic" label="PLG_ALFA_PAYMENTS_REVOLUT_FIELDSET_API">
				<field name="secret_key" type="password" label="PLG_ALFA_PAYMENTS_REVOLUT_SECRET_KEY_LABEL" description="PLG_ALFA_PAYMENTS_REVOLUT_SECRET_KEY_DESC" required="true" size="80"/>
				<field name="sandbox_mode" type="radio" label="PLG_ALFA_PAYMENTS_REVOLUT_SANDBOX_LABEL" description="PLG_ALFA_PAYMENTS_REVOLUT_SANDBOX_DESC" default="1" class="switcher">
					<option value="0">JDISABLED</option>
					<option value="1">JENABLED</option>
				</field>
			</fieldset>
		</fields>
	</config>
</extension>
