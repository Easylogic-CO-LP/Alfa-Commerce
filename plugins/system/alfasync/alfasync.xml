<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>plg_system_alfasync</name>
    <author>Agamemnon Fakas</author>
    <authorEmail>info@easylogic.gr</authorEmail>
    <authorUrl>https://easylogic.gr</authorUrl>
    <copyright>(C) 2024-2026 Easylogic CO LP / Agamemnon Fakas. All rights reserved.</copyright>
    <license>GNU General Public License version 3 or later; see LICENSE</license>
    <version>1.0.0</version>
    <description>PLG_SYSTEM_ALFASYNC_XML_DESCRIPTION</description>
    <!--
        Bundled inside com_alfa. Installed + auto-enabled by script.php.
        Declare in com_alfa.xml:
            <plugins>
                <plugin plugin="alfasync" group="system" />
            </plugins>
    -->
    <namespace path="src">Alfa\Plugin\System\Alfasync</namespace>
    <files>
        <filename plugin="alfasync">services/provider.php</filename>
        <folder>src</folder>
        <folder>services</folder>
        <folder>language</folder>
    </files>
    <languages folder="language">
        <language tag="en-GB">en-GB/plg_system_alfasync.ini</language>
        <language tag="en-GB">en-GB/plg_system_alfasync.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic" label="PLG_SYSTEM_ALFASYNC_FIELDSET_BASIC">
                <!-- User/usergroup/language-table sync and user-delete cleanup are
                     always on (the Alfa tables must stay in step with Joomla);
                     only debug logging is optional. -->
                <field
                    name="debug_log"
                    type="radio"
                    label="PLG_SYSTEM_ALFASYNC_DEBUG_LOG_LABEL"
                    description="PLG_SYSTEM_ALFASYNC_DEBUG_LOG_DESC"
                    layout="joomla.form.field.radio.switcher"
                    default="0"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>