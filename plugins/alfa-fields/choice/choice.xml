    <description>PLG_ALFA_FIELDS_CHOICE_DESC</description>
    <namespace path="src">Joomla\Plugin\AlfaFields\Choice</namespace>
    <files>
        <folder>params</folder>
        <folder plugin="choice">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
