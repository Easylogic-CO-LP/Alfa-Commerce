<?xml version="1.0" encoding="UTF-8"?>
<form>
	<fields name="fieldsparams">
		<fieldset name="fieldparams" label="COM_ALFA_FIELDS_PARAMS_TAB">
			<field
				name="filter"
				type="list"
				label="PLG_ALFA_FIELDS_TEXT_PARAMS_FILTER_LABEL"
				class="list"
				validate="options"
				default="safehtml"
				>
				<option value="0">JNO</option>
				<option value="raw">JLIB_FILTER_PARAMS_RAW</option>
				<option value="safehtml">JLIB_FILTER_PARAMS_SAFEHTML</option>
				<option value="\Joomla\CMS\Component\ComponentHelper::filterText">JLIB_FILTER_PARAMS_TEXT</option>
				<option value="alnum">JLIB_FILTER_PARAMS_ALNUM</option>
				<option value="integer">JLIB_FILTER_PARAMS_INTEGER</option>
				<option value="float">JLIB_FILTER_PARAMS_FLOAT</option>
				<option value="tel">JLIB_FILTER_PARAMS_TEL</option>
			</field>

			<field
				name="maxlength"
				type="number"
				label="PLG_ALFA_FIELDS_TEXT_PARAMS_MAXLENGTH_LABEL"
				filter="integer"
				default="255"
			/>

			<!-- Read by FormfieldModel.php to pick the MySQL column type. Fixed:
			     a text field always stores as varchar(255). Do not remove. -->
			<field name="sql_type" type="hidden" default="varchar(255)"/>

		</fieldset>
	</fields>
</form>
