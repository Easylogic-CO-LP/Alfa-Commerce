<?xml version="1.0" encoding="UTF-8"?>
<!--
    Order Items Form Definition

    Used in TWO contexts (same pattern as order_payments.xml):
    1. LIST (edit_order_items.php): loadSubForm()->getFieldset() for table headers
    2. POPUP (edit_order_item.php): renderFieldset('order_item') for edit form

    Hidden fields: not shown in list table, rendered as <input type="hidden"> in popup
    Visible fields: shown as <th> in list, rendered as form controls in popup
    Readonly fields: displayed in list, shown but not editable in popup
-->
<form>
    <fieldset name="order_item">

        <!-- ======================================================== -->
        <!-- HIDDEN: System fields (not visible in list) -->
        <!-- ======================================================== -->
        <field
                name="id"
                type="hidden"
                default="0"
                readonly="true"
                label="JGLOBAL_FIELD_ID_LABEL"
        />

        <field
                name="id_order"
                type="hidden"
                default="0"
        />

        <field
                name="id_item"
                type="hidden"
                default="0"
                label="COM_ALFA_ORDER_ITEM_PRODUCT_ID"
        />

        <!-- ======================================================== -->
        <!-- VISIBLE: Product snapshot (shown in list + readonly in popup) -->
        <!-- ======================================================== -->
        <field
                name="name"
                type="text"
                label="Product"
                readonly="true"
                class="readonly"
                description=""
        />

        <field
                name="reference"
                type="text"
                label="Sku"
                readonly="true"
                class="readonly"
                description="COM_ALFA_SKU_DESC"
        />

        <!-- ======================================================== -->
        <!-- EDITABLE: Quantity and pricing -->
        <!-- ======================================================== -->
        <field
                name="quantity"
                type="number"
                label="Quantity"
                description=""
                required="true"
                min="1"
                step="1"
                default="1"
        />

        <field
                name="unit_price_tax_incl"
                type="number"
                label="Unit price"
                description=""
                required="true"
                min="0"
                step="0.01"
                hint="0.00"
        />

        <!-- ======================================================== -->
        <!-- READONLY: Calculated fields (auto-computed, display only) -->
        <!-- ======================================================== -->
        <field
                name="unit_price_tax_excl"
                type="text"
                label="Price tax excl"
                readonly="true"
                class="readonly"
        />

        <field
                name="total_price_tax_incl"
                type="text"
                label="Total price"
                readonly="true"
                class="readonly"
        />

        <field
                name="tax_rate"
                type="text"
                label="Tax rate"
                readonly="true"
                class="readonly"
        />

    </fieldset>
</form>