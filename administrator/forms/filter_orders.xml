<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter" addfieldprefix="Alfa\Component\Alfa\Administrator\Field">
        <field name="search" type="text" description="COM_ALFA_SEARCH_FILTER_SUBMIT"
               label="COM_USERS_FILTER_SEARCH_DESC"
               class="js-stools-search-string" />

        <!-- type="model" → Alfa ModelField, sourced from OrderstatusesModel so
             status names come back in the active language. The empty first
             option is the "all statuses" placeholder (single-select). -->
        <field
          name="order_status" type="model"
          model="orderstatuses"
          column_value="id"
          column_text="name"
          input_type="list"
          multiple="false"
          label="COM_ALFA_FORM_LBL_ORDER_STATUSES"
          description="COM_ALFA_FORM_DESC_ORDER_STATUSES"
          layout="joomla.form.field.list-fancy-select"
          onchange="this.form.submit();"
        >
            <option value="">COM_ALFA_FILTER_SELECT_STATUS</option>
        </field>

        <field
          name="show_trashed" type="list"
          multiple="false"
          label="COM_ALFA_FILTER_ORDERS_VIEW"
          layout="joomla.form.field.list-fancy-select"
          onchange="this.form.submit();"
          header="COM_ALFA_FILTER_ORDERS_ACTIVE"
        >
            <option value="1">COM_ALFA_FILTER_ORDERS_TRASHED</option>
        </field>

    </fields>

    <fields name="list">

        <field name="fullordering"
               type="list"
               label="COM_ALFA_LIST_FULL_ORDERING"
               description="COM_ALFA_LIST_FULL_ORDERING_DESC"
               onchange="this.form.submit();"
               default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.id ASC">COM_ALFA_ID_ASC</option>
            <option value="a.id DESC">COM_ALFA_ID_DESC</option>
            <option value="user_name ASC">COM_ALFA_USER_NAME_ASC</option>
            <option value="user_name DESC">COM_ALFA_USER_NAME_DESC</option>
            <option value="a.original_price ASC">COM_ALFA_ORIGINAL_PRICE_ASC</option>
            <option value="a.original_price DESC">COM_ALFA_ORIGINAL_PRICE_DESC</option>
            <option value="a.shipping_tracking_number ASC">COM_ALFA_TRACKING_NUMBER_ASC</option>
            <option value="a.shipping_tracking_number DESC">COM_ALFA_TRACKING_NUMBER_DESC</option>
            <option value="a.created ASC">COM_ALFA_CREATED_ASC</option>
            <option value="a.created DESC">COM_ALFA_CREATED_DESC</option>

        </field>

       <field name="limit"
               type="limitbox"
               label="COM_ALFA_LIST_LIMIT"
               description="COM_ALFA_LIST_LIMIT_DESC"
               class="input-mini"
               default="25"
               onchange="this.form.submit();"
        />

    </fields>

</form>