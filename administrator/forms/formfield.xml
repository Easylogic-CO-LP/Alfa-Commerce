<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Alfa\Component\Alfa\Administrator\Field">

    <field name="name" type="MultilingualText"
           multilingual_table="#__alfa_form_fields" multilingual_pk="id_formfield"
           maxlength="400" filter="safehtml" required="true" translateLabel="true"
           label="COM_ALFA_FORM_LBL_PAYMENT_NAME" description="COM_ALFA_FORM_DESC_PAYMENT_NAME"
           hint="COM_ALFA_FORM_LBL_PAYMENT_NAME"/>


    <fieldset name="general">

        <field
                name="type"
                type="type"
                label="COM_ALFA_FORM_LBL_TYPE_IS"
                default="text"
                required="true"
                list_value="name"
                list_text="name"
                plugin_type="fields"
        />

        <field
                name="field_name"
                type="text"
                label="COM_ALFA_FORM_LBL_FIELD_NAME"
                hint="JFIELD_NAME_PLACEHOLDER"
                required="false"
        />

        <field
                name="field_label"
                type="MultilingualText"
                multilingual_table="#__alfa_form_fields"
                multilingual_pk="id_formfield"
                label="COM_ALFA_FORM_LBL_FIELD_LABEL"
                required="true"
        />

        <field
                name="field_description"
                type="MultilingualTextarea"
                multilingual_table="#__alfa_form_fields"
                multilingual_pk="id_formfield"
                label="COM_ALFA_FORM_LBL_FIELD_DESCRIPTION"
                rows="3"
                required="false"
        />


        <field name="required" type="radio"
               layout="joomla.form.field.radio.switcher"
               label="COM_ALFA_FORM_LBL_REQUIRED"
               description=""
               default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>


        <field name="registration" type="radio"
               layout="joomla.form.field.radio.switcher"
               label="COM_ALFA_FORM_LBL_REGISTRATION"
               description=""
               default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field name="billing" type="radio"
               layout="joomla.form.field.radio.switcher"
               label="COM_ALFA_FORM_LBL_BILLING"
               description=""
               default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field name="shipping" type="radio"
               layout="joomla.form.field.radio.switcher"
               label="COM_ALFA_FORM_LBL_SHIPPING"
               description=""
               default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field name="unique" type="radio"
               layout="joomla.form.field.radio.switcher"
               label="COM_ALFA_FORM_LBL_UNIQUE"
               description=""
               default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field
                name="usergroups"
                type="UserGroupList"
                label="COM_ALFA_FORM_CATEGORY_ALLOWEDUSERGROUPS_LBL"
                description="COM_ALFA_FORM_CATEGORY_ALLOWEDUSERGROUPS_DESC"
                layout="joomla.form.field.list-fancy-select"
                multiple="true"
                checksuperusergroup="1"
                default="8"
                header="COM_ALFA_FORM_HEADER_ALL_USERGROUPS"
        />

        <field
                name="users" type="sql"
                input_type="list"
                required="false"
                multiple="true"
                label="COM_ALFA_FORM_CATEGORY_ALLOWEDUSERS_LBL"
                description="COM_ALFA_FORM_CATEGORY_ALLOWEDUSERS_DESC"
                layout="joomla.form.field.list-fancy-select"
                query="SELECT `id`, `name` FROM `#__users`" key_field="id" value_field="name"
        />

    </fieldset>


    <fieldset name="publish">
        <field name="state" default="1" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox"
               size="1">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="2">JARCHIVED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <field name="group_id" type="sql"
               default="0"
               label="COM_ALFA_FORM_LBL_FIELD_GROUP"
               description="COM_ALFA_FORM_DESC_FIELD_GROUP"
               query="SELECT id AS value, CONCAT(title, IF(state = 0, ' (disabled)', '')) AS text FROM #__alfa_form_field_groups ORDER BY ordering ASC"
               key_field="value" value_field="text">
            <option value="0">COM_ALFA_FORM_OPTION_FIELD_GROUP_NONE</option>
        </field>

        <field name="layout" type="fieldLayout"
               label="JFIELD_ALT_LAYOUT_LABEL"
               description="COM_ALFA_FORM_DESC_FIELD_LAYOUT"
               class="form-select"/>

        <field
                name="created_by"
                type="user"
                label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                validate="UserId"
        />

        <field
                name="modified_by"
                type="user"
                label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                class="readonly"
                readonly="true"
                filter="unset"
                validate="UserId"
        />

        <field
                name="modified"
                type="calendar"
                label="JGLOBAL_FIELD_MODIFIED_LABEL"
                class="form-control"
                translateformat="true"
                showtime="true"
                readonly="true"
                filter="user_utc"
        />

        <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>

    </fieldset>

    <field name="ordering"/>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" type="hidden" filter="unset"/>

    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL"
           description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>

    <!-- ===== SHOWON: standalone builder field. Value carried by a hidden
         input; showon-builder.js renders the UI and writes canonical JSON
         back into it. No fieldsparams wrapper — FormfieldModel folds the
         value into params on save and mirrors it back on load. Rendered
         manually as its own tab in tmpl/formfield/edit.php. ===== -->
    <field
            name="showon"
            type="showon"
            label="COM_ALFA_SHOWON_LBL"
            description="COM_ALFA_SHOWON_DESC"
            hiddenLabel="true"
    />
    <!-- ===== /SHOWON ===== -->
</form>

