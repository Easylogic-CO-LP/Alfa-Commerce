<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text"
               label="COM_ALFA_SEARCH_FILTER_SUBMIT"
               description="COM_ALFA_SEARCH_FILTER_SUBMIT"
               class="js-stools-search-string" />

        <field name="scope" type="list"
               label="COM_ALFA_NOTIFY_FILTER_SCOPE"
               onchange="this.form.submit();">
            <option value="">COM_ALFA_NOTIFY_SCOPE_HISTORY</option>
            <option value="active">COM_ALFA_NOTIFY_SCOPE_ACTIVE</option>
        </field>

        <field name="severity" type="list"
               label="COM_ALFA_NOTIFY_COL_SEVERITY"
               onchange="this.form.submit();">
            <option value="">JOPTION_SELECT_ALL</option>
            <option value="danger">COM_ALFA_NOTIFY_SEVERITY_DANGER</option>
            <option value="warning">COM_ALFA_NOTIFY_SEVERITY_WARNING</option>
            <option value="info">COM_ALFA_NOTIFY_SEVERITY_INFO</option>
            <option value="success">COM_ALFA_NOTIFY_SEVERITY_SUCCESS</option>
        </field>

        <field name="read" type="list"
               label="COM_ALFA_NOTIFY_FILTER_READ"
               onchange="this.form.submit();">
            <option value="">JOPTION_SELECT_ALL</option>
            <option value="unread">COM_ALFA_NOTIFY_UNREAD</option>
            <option value="read">COM_ALFA_NOTIFY_READ</option>
        </field>
    </fields>

    <fields name="list">
        <field name="fullordering" type="list"
               label="COM_ALFA_LIST_FULL_ORDERING"
               onchange="this.form.submit();"
               default="a.created DESC">
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.created ASC">COM_ALFA_NOTIFY_SORT_CREATED_ASC</option>
            <option value="a.created DESC">COM_ALFA_NOTIFY_SORT_CREATED_DESC</option>
            <option value="a.severity ASC">COM_ALFA_NOTIFY_SORT_SEVERITY_ASC</option>
            <option value="a.severity DESC">COM_ALFA_NOTIFY_SORT_SEVERITY_DESC</option>
            <option value="a.notify_group ASC">COM_ALFA_NOTIFY_SORT_GROUP_ASC</option>
            <option value="a.notify_group DESC">COM_ALFA_NOTIFY_SORT_GROUP_DESC</option>
        </field>

        <field name="limit" type="limitbox"
               label="COM_ALFA_LIST_LIMIT"
               class="input-mini"
               default="25"
               onchange="this.form.submit();" />
    </fields>
</form>
